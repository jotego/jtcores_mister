<misterromdescription>
    <about author="Solal Jacob" webpage="https://ko-fi.com/solalretrogaming" twitter="@s_on_vg" source="https://jotego/jtcores"/>
    <rotation>horizontal</rotation>
    <name>Cabal (Korea?, Joystick)</name>
    <setname>cabala</setname>
    <mameversion>0282</mameversion>
    <year>1989</year>
    <manufacturer>TAD Corporation (Alpha Trading license)</manufacturer>
    <players>2</players>
    <rbf>jttoki</rbf>
    <joystick>8</joystick>
    <region>World</region>
    <rom index="0" zip="cabala.zip|cabal.zip" md5="None" asm_md5="13366b66ba641342489832a686429b79">
        <!--     byte 0: 00 = Toki/Juju
            01 = Cabal joystick hardware
 -->
        <part>
            01 00 00 00 </part>
        <!-- maincpu - starts at 0x0 - length 0x60000 (19 bits) -->
        <interleave output="16">
            <part name="epr-a-7.6h" crc="c89608db" map="01"/>
            <part name="epr-a-9.7h" crc="00abbe0c" map="10"/>
        </interleave>
        <interleave output="16">
            <part name="epr-a-6.6k" crc="81eb1355" map="01"/>
            <part name="epr-a-8.7k" crc="fe84788a" map="10"/>
        </interleave>
        <part repeat="0x30000"> FF</part>
        <!-- JTFRAME_BA1_START -->
        <!-- audiocpu - starts at 0x60000 - length 0x6000 (15 bits) -->
        <part name="epr-a-4.3n" crc="4038eff2"/>
        <part name="epr-a-3.3p" crc="c0097c55"/>
        <!-- oki - starts at 0x66000 - length 0xE000 (16 bits) -->
        <part repeat="0xE000"> FF</part>
        <!-- ADPCM1_START -->
        <!-- adpcm1 - starts at 0x74000 - length 0x10000 (16 bits) -->
        <part name="epr-a-2.1s" crc="850406b4"/>
        <!-- ADPCM2_START -->
        <!-- adpcm2 - starts at 0x84000 - length 0x10000 (16 bits) -->
        <part name="epr-a-1.1u" crc="8b3e0789"/>
        <!-- JTFRAME_BA2_START -->
        <!-- chars - starts at 0x94000 - length 0x20000 (17 bits) -->
        <part name="epr-a-5.6s" crc="189033fd"/>
        <part repeat="0x18000"> FF</part>
        <!-- GFX3_START -->
        <!-- bgtiles - starts at 0xB4000 - length 0x80000 (19 bits) -->
        <part name="tad-2.7s" crc="13ca7ae1"/>
        <!-- fgtiles - starts at 0x134000 - length 0x80000 (19 bits) -->
        <part repeat="0x80000"> FF</part>
        <!-- JTFRAME_BA3_START -->
        <!-- sprites - starts at 0x1B4000 - length 0x80000 (19 bits) -->
        <part name="tad-1.5e" crc="8324a7fe"/>
        <!-- proms - starts at 0x234000 - length 0x200 (9 bits) -->
        <part name="prom05.8e" crc="a94b18c2"/>
        <part name="prom10.4j" crc="261c93bc"/>
        <!-- Total 0x234200 bytes - 2256 kBytes -->
    </rom>
    <nvram index="2" size="12288"/>
    <rom index="1">
        <part>00 80</part>
    </rom>
    <switches page_id="1" page_name="Switches" base="16" default="ff,ef">
        <DSW/>
        <dip name="Coin Mode" bits="4" ids="Mode 2,Mode 1"/>
        <dip name="Invert Buttons" bits="5" ids="On,Off"/>
        <dip name="Flip Screen" bits="6" ids="On,Off"/>
        <dip name="Trackball" bits="7" ids="Large,Small"/>
        <dip name="Lives" bits="8,9" ids="121,5,2,3"/>
        <dip name="Bonus Life" bits="10,11" ids="300k Only,300k 1000k 700k+,200k 800k 600k+,150k 650k 500k+"/>
        <dip name="Difficulty" bits="12,13" ids="Very Hard,Hard,Normal,Easy"/>
        <dip name="Unknown" bits="14" ids="On,Off"/>
        <dip name="Demo Sounds" bits="15" ids="Off,On"/>
    </switches>
    <buttons names="Fire,Grenade,Roll,Start,Coin,Core credits" default="A,B,X,Start,Select,-" count="3"/>
</misterromdescription>
